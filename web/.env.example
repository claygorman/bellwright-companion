# Bellwright Companion — web app environment
# Copy to .env.local and adjust. Next.js loads .env.local automatically.

# Database connection.
#   sqlite:    file:<path>            (default: file:./.data/bellwright.db)
#   postgres:  postgres://user:pass@host:5432/bellwright   (dialect planned)
DATABASE_URL=file:./.data/bellwright.db

# Where ingest artifacts live (latest.sav, payload.bin, and the default sqlite db)
DATA_DIR=./.data

# Path to the Oodle decompressor binary (tools/dump)
DUMP_BIN=../tools/dump/target/release/dump

# Drizzle migrations folder (only override in containers)
# MIGRATIONS_DIR=./drizzle

# Retention: keep only the newest N snapshots (unset = keep full history)
# SNAPSHOT_KEEP=500
